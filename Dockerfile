# 1. Используем официальный легковесный образ Python
FROM python:3.11-slim

# 2. Устанавливаем рабочую директорию внутри контейнера
WORKDIR /app

# 3. Отключаем буферизацию логов Python (чтобы сразу видеть ошибки в терминале)
ENV PYTHONUNBUFFERED=1

# 4. Сначала копируем только файл со списком зависимостей
# Это нужно для кеширования слоев (ускоряет последующие сборки Docker)
COPY requirements.txt .

# 5. Устанавливаем библиотеки
RUN pip install --no-cache-dir -r requirements.txt

# 6. Копируем весь остальной исходный код проекта
COPY . .

# 7. Команда для запуска приложения (замените main.py на ваш файл)
CMD ["python", "scraper.py"]
